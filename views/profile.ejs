<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile — Sneacks</title>
  <link rel="stylesheet" href="/styles/global.css?v=2" />
  <link rel="stylesheet" href="/styles/profile.css?v=6" />
</head>

<body>

  <!-- ===== NAV ===== -->
  <nav class="site-nav">
    <a href="/home" class="nav-brand">Sneacks</a>
    <ul class="nav-links">
      <li><a href="/home">Home</a></li>
      <li><a href="#">Store</a></li>
      <li><a href="#">About Us</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
    <div class="nav-icons">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="11" cy="11" r="7" />
        <line x1="16.5" y1="16.5" x2="22" y2="22" />
      </svg>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
      </svg>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
        <circle cx="12" cy="7" r="4" />
      </svg>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
        <line x1="3" y1="6" x2="21" y2="6" />
        <path d="M16 10a4 4 0 0 1-8 0" />
      </svg>
    </div>
  </nav>

  <div class="account-layout">

    <aside class="account-sidebar">
      <h3 class="sidebar-title">MY ACCOUNT</h3>
      <ul class="sidebar-menu">
        <li><a href="/profile" class="active">PROFILE</a></li>
        <li><a href="/orders">ORDERS</a></li>
        <li><a href="/address">ADDRESS</a></li>
        <li><a href="/wallet">WALLET</a></li>
      </ul>
    </aside>

    <main class="account-main">

      <div class="account-header">
        <span class="account-tag">PERSONAL WORKSPACE</span>
        <h1 class="account-heading">Profile Details</h1>
      </div>

      <div class="profile-photo-wrap">
        <% if (user.profileImage) { %>
          <img src="<%= user.profileImage %>" alt="Profile" id="mainProfileImage">
          <div class="avatar-letter" id="mainDefaultAvatar" style="display: none;">
            <%= user.name.charAt(0).toUpperCase() %>
          </div>
        <% } else { %>
          <div class="avatar-letter" id="mainDefaultAvatar">
            <%= user.name.charAt(0).toUpperCase() %>
          </div>
        <% } %>
      </div>

      <div class="profile-details-grid">
        <div class="detail-item full-width">
          <div class="detail-label">FULL NAME</div>
          <div class="detail-value"><%= user.name %></div>
          <button class="btn-edit-icon" onclick="openModal('editProfileModal')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
            </svg>
          </button>
        </div>

        <div class="detail-item full-width">
          <div class="detail-label">EMAIL ADDRESS</div>
          <div class="detail-value">
            <%= user.email %>
            <% if (user.isVerified) { %>
              <span class="badge-verified">VERIFIED</span>
            <% } %>
          </div>
        </div>

        <div class="detail-item">
          <div class="detail-label">PHONE NUMBER</div>
          <div class="detail-value"><%= user.phone %></div>
        </div>

        <div class="detail-item">
          <div class="detail-label">DATE OF BIRTH</div>
          <div class="detail-value"><%= user.dob %></div>
        </div>
      </div>

      <!-- FIX 2: Security & Referral cards moved INSIDE <main> -->

      <!-- Security Card -->
      <div class="account-card security-card">
        <div class="security-info">
          <h3>Security</h3>
          <p>Ensure your account remains protected with a strong password.</p>
        </div>
        <button class="btn-secondary" onclick="openModal('updatePasswordModal')">Update Password</button>
      </div>

      <!-- Referral Card -->
      <div class="account-card referral-card">
        <div class="referral-info">
          <h3>Referral Program</h3>
          <div class="detail-label">YOUR REFERRAL CODE</div>
          <div class="referral-code-box">
            <span class="code">ELARA10</span>
            <button class="btn-copy">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              Copy
            </button>
          </div>
          <div class="referral-hint">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            Share this code with friends and earn rewards
          </div>
        </div>
        <div class="referral-bg-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <polyline points="20 12 20 22 4 22 4 12"></polyline>
            <rect x="2" y="7" width="20" height="5"></rect>
            <line x1="12" y1="22" x2="12" y2="7"></line>
            <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
            <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
          </svg>
        </div>
      </div>

    </main><!-- /account-main -->

  </div><!-- /account-layout  FIX 3: Closed account-layout -->

  <!-- ===== UPDATE PASSWORD MODAL ===== -->
  <!-- ===== UPDATE PASSWORD MODAL ===== -->
<div class="modal-overlay" id="updatePasswordModal">
  <div class="modal-content modal-md">

    <div class="modal-header-centered">
      <span class="modal-tag">ACCOUNT SETTINGS</span>
      <h2>Update Password</h2>
      <p>Update your password to keep your account secure.</p>
    </div>

    <div class="modal-body-card">

      <!-- ✅ FORM INSIDE MODAL -->
      <form action="/update-password" method="POST" class="edit-form">

        <div class="form-group full-width">
          <label class="form-label">CURRENT PASSWORD</label>
          <div class="password-input-wrap">
            <input type="password" name="currentPassword" class="form-input-box" required>
            <button type="button" class="btn-eye" onclick="togglePassword(this)">👁</button>
          </div>
        </div>

        <div class="form-group full-width">
          <label class="form-label">NEW PASSWORD</label>
          <div class="password-input-wrap">
            <input type="password" name="newPassword" class="form-input-box" required>
            <button type="button" class="btn-eye" onclick="togglePassword(this)">👁</button>
          </div>
        </div>

        <div class="form-group full-width">
          <label class="form-label">CONFIRM PASSWORD</label>
          <div class="password-input-wrap">
            <input type="password" name="confirmPassword" class="form-input-box" required>
            <button type="button" class="btn-eye" onclick="togglePassword(this)">👁</button>
          </div>
        </div>

        <div class="modal-actions">
          <button type="button" class="btn-text" onclick="closeModal('updatePasswordModal')">CANCEL</button>
          <button type="submit" class="btn-primary-sm">UPDATE PASSWORD</button>
        </div>

      </form>

    </div>
  </div>
</div>
  <!-- ===== EDIT PROFILE MODAL ===== -->
  <div class="modal-overlay" id="editProfileModal">
    <div class="modal-content modal-md">

      <div class="modal-header-centered">
        <span class="modal-tag">ACCOUNT SETTINGS</span>
        <h2>Edit Profile</h2>
        <p>Manage your personal details and how we contact you.</p>
      </div>

      <div class="modal-body-card">
        <form action="/update-profile" method="POST" enctype="multipart/form-data" class="edit-form grid-form">

          <div class="modal-photo-edit">
            <div class="photo-wrap" onclick="triggerUpload()" style="cursor: pointer;">
              <% if (user.profileImage) { %>
                <img src="<%= user.profileImage %>?t=<%= Date.now() %>" id="currentProfileImage" />
                <div class="avatar-letter" id="defaultAvatar" style="display: none;">
                  <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <button type="button" class="btn-remove-photo" onclick="removePhoto(event)" title="Remove Photo">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </button>
              <% } else { %>
                <div class="avatar-letter">
                  <%= user.name.charAt(0).toUpperCase() %>
                </div>
              <% } %>
              <input type="file" id="profileUpload" name="profileImage" accept="image/*" hidden>
              <input type="hidden" id="removeImageFlag" name="removeImage" value="false">
            </div>
            <div class="change-photo-text">CHANGE PHOTO</div>
            <div class="user-name"><%= user.name %></div>
          </div>

          <div class="form-group" id="field-name">
  <label class="form-label">FULL NAME</label>
  <input type="text" name="name" class="form-input-box" value="<%= user.name %>" required>
</div>

<div class="form-group" id="field-email">
  <label class="form-label">EMAIL ADDRESS</label>
  <input type="email" name="email" class="form-input-box" value="<%= user.email %>" required>
</div>

<div class="form-group" id="field-phone">
  <label class="form-label">PHONE NUMBER</label>
  <input type="text" name="phone" class="form-input-box" value="<%= user.phone || '' %>">
</div>

<div class="form-group" id="field-dob">
  <label class="form-label">DATE OF BIRTH</label>
  <input type="date" name="dob" class="form-input-box" value="<%= user.dob || '' %>">
</div>
          <div class="modal-actions">
            <button type="button" class="btn-text" onclick="closeModal('editProfileModal')">CANCEL</button>
            <button type="submit" class="btn-primary-sm">SAVE CHANGES</button>
          </div>

        </form>
      </div>

    </div>
  </div>

  <!-- ===== SITE FOOTER ===== -->
  <!-- FIX 4: Brand corrected to SNEACKS -->
  <footer class="site-footer">
    <div class="footer-grid">
      <div>
        <div class="footer-brand-name">SNEACKS</div>
        <p class="footer-brand-desc">
          A CURATED SPACE FOR THOSE WHO VALUE THE ART OF THE STEP. ARCHITECTURAL FOOTWEAR DESIGNED FOR THE MODERN ICONOCLAST.
        </p>
      </div>
      <div>
        <div class="footer-col-title">DISCOVER</div>
        <ul class="footer-col-links">
          <li><a href="#">COLLECTIONS</a></li>
          <li><a href="#">LIMITED EDITS</a></li>
          <li><a href="#">THE PROCESS</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">SERVICE</div>
        <ul class="footer-col-links">
          <li><a href="#">SHIPPING</a></li>
          <li><a href="#">RETURNS</a></li>
          <li><a href="#">CARE GUIDE</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom" style="display:flex; justify-content:space-between; align-items:center;">
      <span>© 2024 SNEACKS. CRAFTED FOR THE CURATED FOOT.</span>
      <div style="display:flex; gap:20px;">
        <a href="#">PRIVACY POLICY</a>
        <a href="#">TERMS OF SERVICE</a>
      </div>
    </div>
  </footer>

  <script>
    function openModal(id) {
      document.getElementById(id).classList.add('active');
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
    }

    function triggerUpload() {
      document.getElementById('profileUpload').click();
    }

    // FIX 5: Click backdrop to close modal
    document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) {
          overlay.classList.remove('active');
        }
      });
    });

    function removePhoto(event) {
      event.stopPropagation(); // Don't trigger the upload click
      
      // Update Modal
      var currentImg = document.getElementById('currentProfileImage');
      if(currentImg) currentImg.style.display = 'none';
      var defaultAvatar = document.getElementById('defaultAvatar');
      if(defaultAvatar) defaultAvatar.style.display = 'flex';
      
      // Update Main Profile Page (live preview)
      var mainImg = document.getElementById('mainProfileImage');
      if(mainImg) mainImg.style.display = 'none';
      var mainDefaultAvatar = document.getElementById('mainDefaultAvatar');
      if(mainDefaultAvatar) mainDefaultAvatar.style.display = 'flex';
      
      // Set Flag for Backend
      var flag = document.getElementById('removeImageFlag');
      if(flag) flag.value = 'true';
      
      event.target.style.display = 'none'; // hide the X button
    }
    function togglePassword(btn) {
      const input = btn.previousElementSibling;
      if (input.type === 'password') {
        input.type = 'text';
      } else {
        input.type = 'password';
      }
    }

    function checkStrength(val) {
      const bar1 = document.getElementById('bar1');
      const bar2 = document.getElementById('bar2');
      const bar3 = document.getElementById('bar3');
      const text = document.getElementById('strengthText');

      let strength = 0;
      if (val.length >= 8) strength += 1;
      if (/[A-Za-z]/.test(val) && /[0-9]/.test(val)) strength += 1;
      if (/[^A-Za-z0-9]/.test(val) && val.length >= 8) strength += 1;

      bar1.style.background = strength >= 1 ? '#e1a95f' : 'var(--border)';
      bar2.style.background = strength >= 2 ? '#8f9a82' : 'var(--border)';
      bar3.style.background = strength >= 3 ? '#627351' : 'var(--border)';

      if (val.length === 0) {
        bar1.style.background = 'var(--border)';
        text.innerText = 'WEAK';
      } else if (strength === 1) {
        text.innerText = 'LOW';
      } else if (strength === 2) {
        text.innerText = 'MEDIUM';
      } else if (strength >= 3) {
        text.innerText = 'STRONG';
      }
    }
  </script>
</body>
</html>