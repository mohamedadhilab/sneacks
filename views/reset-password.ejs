<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sneacks — Set New Password</title>

  <!-- ✅ Correct static path -->
  <link rel="stylesheet" href="/styles/global.css" />

  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background-color: var(--cream);
      font-family: 'Montserrat', sans-serif;
    }

    .main-row {
      display: flex;
      flex: 1;
    }

    /* LEFT IMAGE */
   .left-panel {
  width: 50%;
  height: 100vh; /* FULL HEIGHT */
  overflow: hidden;
  position: relative;
}

.left-panel img {
  width: 100%;
  height: 100%;
  object-fit: cover; /* 🔥 THIS IS THE KEY */
  display: block;
}

    .left-caption {
      position: absolute;
      bottom: 40px;
      left: 40px;
      color: rgba(255, 255, 255, 0.6);
      font-style: italic;
    }

    /* RIGHT SIDE */
    .right-panel {
      width: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: var(--cream);
      padding: 40px;
    }

    .logo {
      margin-bottom: 30px;
      text-align: center;
    }

    .logo-title {
      font-size: 28px;
      letter-spacing: 4px;
      font-weight: 600;
    }

    .logo-sub {
      font-size: 10px;
      letter-spacing: 2px;
      color: gray;
    }

    .card {
      background: #f5f2ec;
      padding: 40px;
      border-radius: 6px;
      width: 100%;
      max-width: 380px;
      text-align: center;
    }

    .card h2 {
      margin-bottom: 10px;
      font-family: 'Playfair Display', serif;
    }

    .card p {
      font-size: 12px;
      color: #777;
      margin-bottom: 30px;
    }

    input {
      width: 100%;
      padding: 12px;
      margin-bottom: 16px;
      border: 1px solid #ccc;
      border-radius: 4px;
      outline: none;
    }

    button {
      width: 100%;
      padding: 12px;
      background: #5b633f;
      color: white;
      border: none;
      border-radius: 4px;
      letter-spacing: 2px;
      cursor: pointer;
    }

    button:hover {
      opacity: 0.9;
    }

    .error-text {
      color: red;
      font-size: 12px;
      margin-bottom: 10px;
    }

    .success-text {
      color: green;
      font-size: 12px;
      margin-bottom: 10px;
    }

    .back-link {
      display: block;
      margin-top: 15px;
      font-size: 12px;
      color: #555;
      text-decoration: none;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    .footer {
      text-align: center;
      padding: 10px;
      font-size: 10px;
      color: #999;
      border-top: 1px solid #eee;
    }
  </style>
</head>

<body>

  <div class="main-row">

    <!-- LEFT -->
    <div class="left-panel">
      <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=700&q=80" />
      <div class="left-caption">Spring Collection 2024</div>
    </div>

    <!-- RIGHT -->
    <div class="right-panel">

      <div class="logo">
        <div class="logo-title">SNEACKS</div>
        <div class="logo-sub">THE CURATED ATELIER</div>
      </div>

      <div class="card">

        <h2>Set New Password</h2>
        <p>Please enter your new password below</p>

        <!-- ✅ ERROR HANDLING SAFE -->
        <% if (typeof error !== 'undefined') { %>
          <div class="error-text"><%= error %></div>
        <% } %>

        <% if (typeof success !== 'undefined') { %>
          <div class="success-text"><%= success %></div>
        <% } %>

        <!-- ✅ FORM -->
        <form action="/reset-password" method="POST">

          <!-- ✅ ONLY EMAIL (NO PURPOSE) -->
          <input type="hidden" name="email" value="<%= email %>" />

          <input 
            type="password" 
            name="password" 
            placeholder="New Password" 
            required 
          />

          <input 
            type="password" 
            name="confirmPassword" 
            placeholder="Confirm Password" 
            required 
          />

          <button type="submit">UPDATE PASSWORD</button>

        </form>

        <a href="/login" class="back-link">← Back to Login</a>

      </div>

    </div>
  </div>

  <div class="footer">
    © 2024 Sneacks Atelier. All Rights Reserved.
  </div>

</body>

</html>