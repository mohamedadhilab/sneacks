<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Shop | SNEACKS
    </title>

    <!-- Icons -->

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    >

    <!-- CSS -->

    <link
        rel="stylesheet"
        href="/styles/user/base.css"
    >

    <link
        rel="stylesheet"
        href="/styles/user/layout.css?v=12"
    >

    <link
        rel="stylesheet"
        href="/styles/user/components.css"
    >

    <link
        rel="stylesheet"
        href="/styles/user/animations.css"
    >

    <link
        rel="stylesheet"
        href="/styles/user/shop.css"
    >

    <link
        rel="stylesheet"
        href="/styles/user/responsive.css"
    >

</head>

<body>

<!-- NAVBAR -->

<%- include('../partials/user/navbar', { page: 'shop' }) %>

<main class="page-wrapper">

    <!-- ===================================================== -->
    <!-- HEADER -->
    <!-- ===================================================== -->

    <section class="shop-header text-center animate-fade-up">

        <div class="container">

            <span class="uppercase-label">

                Curated Collection

            </span>

            <h1>

                The Architectural
                Footwear Gallery

            </h1>

            <p class="text-muted">

                Explore timeless silhouettes crafted
                for the modern explorer.

            </p>

        </div>

    </section>

    <!-- ===================================================== -->
    <!-- SHOP -->
    <!-- ===================================================== -->

    <section class="section pt-0">

        <div class="container">

            <!-- TOPBAR -->

            <div class="shop-topbar animate-fade-in">

                <button
                    class="btn btn-secondary mobile-filter-btn"
                    id="mobileFilterBtn"
                >

                    <i class="fas fa-sliders-h"></i>

                    Filters

                </button>

                <div class="shop-meta">

                    <span class="uppercase-label text-muted">

                        DISPLAYING

                        <%= totalProducts || 0 %>

                        PRODUCTS

                    </span>

                </div>

                <!-- SORT -->

                <form
                    action="/shop"
                    method="GET"
                    class="sort-form"
                >

                    <!-- PRESERVE FILTERS -->

                    <input
                        type="hidden"
                        name="search"
                        value="<%= search || '' %>"
                    >

                    <% if(selectedCategories){ %>

                        <% selectedCategories.forEach(cat => { %>

                            <input
                                type="hidden"
                                name="category"
                                value="<%= cat %>"
                            >

                        <% }) %>

                    <% } %>

                    <input
                        type="hidden"
                        name="minPrice"
                        value="<%= minPrice || '' %>"
                    >

                    <input
                        type="hidden"
                        name="maxPrice"
                        value="<%= maxPrice || '' %>"
                    >

                    <select
                        class="form-input custom-select"
                        name="sort"
                        onchange="this.form.submit()"
                    >

                        <option value="">
                            Sort By
                        </option>

                        <option
                            value="price-low"
                            <%= sort === 'price-low'
                                ? 'selected'
                                : ''
                            %>
                        >
                            Price Low to High
                        </option>

                        <option
                            value="price-high"
                            <%= sort === 'price-high'
                                ? 'selected'
                                : ''
                            %>
                        >
                            Price High to Low
                        </option>

                        <option
                            value="a-z"
                            <%= sort === 'a-z'
                                ? 'selected'
                                : ''
                            %>
                        >
                            A - Z
                        </option>

                        <option
                            value="z-a"
                            <%= sort === 'z-a'
                                ? 'selected'
                                : ''
                            %>
                        >
                            Z - A
                        </option>

                    </select>

                </form>

            </div>

            <!-- SHOP LAYOUT -->

            <div class="shop-layout">

                <!-- ================================================= -->
                <!-- SIDEBAR -->
                <!-- ================================================= -->

                <aside
                    class="shop-sidebar"
                    id="shopSidebar"
                >

                    <div class="sidebar-header mobile-only">

                        <h3>

                            Filters

                        </h3>

                        <button
                            class="btn-icon"
                            id="closeFilterBtn"
                        >

                            <i class="fas fa-times"></i>

                        </button>

                    </div>

                    <!-- FILTER FORM -->

                    <form
                        id="filterForm"
                        action="/shop"
                        method="GET"
                    >

                        <!-- SEARCH -->

                        <div class="filter-group">

                            <h4 class="filter-title">

                                Search

                            </h4>

                            <input
                                type="text"
                                name="search"
                                class="form-input"
                                placeholder="Search products..."
                                value="<%= search || '' %>"
                            >

                            <% if(search){ %>

                                <a
                                    href="/shop"
                                    class="clear-search-link"
                                >
                                         <i class="fas fa-times"></i>

                                    Clear 

                                </a>

                            <% } %>

                        </div>

                        <!-- CATEGORY -->

                        <div class="filter-group">

                            <h4 class="filter-title">

                                Categories

                            </h4>

                            <ul class="filter-list">

                                <% categories.forEach(cat => { %>

                                    <li>

                                        <label class="filter-checkbox">

                                            <input
                                                type="checkbox"
                                                name="category"
                                                value="<%= cat._id %>"

                                                <%= selectedCategories &&
                                                    selectedCategories.includes(
                                                        cat._id.toString()
                                                    )

                                                    ? 'checked'

                                                    : ''
                                                %>
                                            >

                                            <span class="checkmark"></span>

                                            <%= cat.category_name %>

                                        </label>

                                    </li>

                                <% }) %>

                            </ul>

                        </div>

                        <!-- PRICE -->

                        <div class="filter-group">

                            <h4 class="filter-title">

                                Price Range

                            </h4>

                            <div class="price-inputs">

                                <input
                                    type="number"
                                    name="minPrice"
                                    class="form-input"
                                    placeholder="Min"
                                    value="<%= minPrice || '' %>"
                                >

                                <span>-</span>

                                <input
                                    type="number"
                                    name="maxPrice"
                                    class="form-input"
                                    placeholder="Max"
                                    value="<%= maxPrice || '' %>"
                                >

                            </div>

                        </div>

                        <!-- SORT HIDDEN -->

                        <input
                            type="hidden"
                            name="sort"
                            value="<%= sort || '' %>"
                        >

                        <!-- ACTIONS -->

                        <div class="filter-actions">

                            <button
                                type="submit"
                                class="btn btn-primary btn-full"
                            >

                                Apply Filters

                            </button>

                            <a
                                href="/shop"
                                class="btn btn-secondary btn-full"
                            >

                                Clear All

                            </a>

                        </div>

                    </form>

                </aside>

                <!-- MOBILE OVERLAY -->

                <div
                    class="sidebar-overlay"
                    id="sidebarOverlay"
                ></div>

                <!-- ================================================= -->
                <!-- PRODUCTS -->
                <!-- ================================================= -->

                <div class="shop-grid">

                    <% if(products && products.length > 0){ %>

                        <div class="grid grid-3">

                            <% products.forEach(product => { %>

                                <%- include(
                                    '../partials/user/product-card',
                                    { product }
                                ) %>

                            <% }) %>

                        </div>


                            <!-- PAGINATION -->

                    <% if(totalPages > 1){ %>

                    <div class="premium-pagination">

                        <!-- PREVIOUS -->

                        <% if(currentPage > 1){ %>

                            <a

                                href="/shop?page=<%= currentPage - 1 %>&<%= queryString %>"

                                class="pagination-arrow"

                            >

                                <i class="fas fa-chevron-left"></i>

                            </a>

                        <% } %>

                        <!-- PAGE NUMBERS -->

                        <div class="pagination-numbers">

                            <% for(let i = 1; i <= totalPages; i++){ %>

                                <a

                                    href="/shop?page=<%= i %>&<%= queryString %>"

                                    class="pagination-number
                                    <%= currentPage === i
                                        ? 'active-page'
                                        : ''
                                    %>"

                                >

                                    <%= i %>

                                </a>

                            <% } %>

                        </div>

                        <!-- NEXT -->

                        <% if(currentPage < totalPages){ %>

                            <a

                                href="/shop?page=<%= currentPage + 1 %>&<%= queryString %>"

                                class="pagination-arrow"

                            >

                                <i class="fas fa-chevron-right"></i>

                            </a>

                        <% } %>

                    </div>
                        <% } %>

                    <% } else { %>

                        <!-- EMPTY STATE -->

                        <%- include(
                            '../partials/user/empty-state',
                            {
                                iconClass: 'fas fa-search',
                                title: 'No Products Found',
                                message:
                                    'Try changing filters or search.',
                                actionText: 'Clear Filters',
                                actionLink: '/shop'
                            }
                        ) %>

                    <% } %>

                </div>

            </div>

        </div>

    </section>

</main>

<!-- FOOTER -->

<%- include('../partials/user/footer') %>

<!-- JS -->

<script src="/js/user/shop.js"></script>

</body>
</html>