<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="View comprehensive tracking info and invoices for your SNEACKS order.">
    <title>Order Details | SNEACKS</title>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- CSS -->
    <link rel="stylesheet" href="/styles/user/base.css">
    <link rel="stylesheet" href="/styles/user/layout.css?v=12">
    <link rel="stylesheet" href="/styles/user/components.css">
    <link rel="stylesheet" href="/styles/user/animations.css">
    <link rel="stylesheet" href="/styles/user/order-details.css">
    <link rel="stylesheet" href="/styles/user/responsive.css">
</head>

<body>

    <!-- NAVBAR -->
    <%- include('../partials/user/navbar', { page: 'orders' }) %>

    
<%

const statusSteps = [

    {
        name:'Pending',
        icon:'fa-check'
    },

    {
        name:'Processing',
        icon:'fa-cog'
    },

    {
        name:'Shipped',
        icon:'fa-truck'
    },

    {
        name:'Out For Delivery',
        icon:'fa-shipping-fast'
    },

    {
        name:'Delivered',
        icon:'fa-box-open'
    }

];


const currentStatusIndex = 
statusSteps.findIndex(

    step =>
    step.name.toLowerCase() === 
    order.orderStatus.toLowerCase()

);


const dateFormatted = 
new Date(order.createdAt)
.toLocaleDateString(
'en-US',
{

    month:'long',

    day:'numeric',

    year:'numeric'

});


%>

    <main class="page-wrapper">
        <div class="container order-detail-container section">
            
            <!-- HEADER SECTION -->
            <div class="detail-header animate-fade-up">
                <div class="header-main">
                    <h1 class="detail-title">Order Details</h1>
                    <p class="detail-meta">
                        <span class="detail-id">#<%= order.orderId %></span>
                        <span class="meta-dot">•</span>
                        <span class="detail-date">Placed <%= dateFormatted %></span>
                    </p>
                </div>
                <div class="header-action">
                    <a 
                    href="/download-invoice/<%= order._id %>"
                    class="btn btn-secondary download-invoice-btn"
                    >

                    <i class="fas fa-file-invoice"></i>

                    Download Invoice

                    </a>                     
                </div>
            </div>

            <!-- ORDER PROGRESS TRACKER -->
             <% if(order.orderStatus !== 'Cancelled') { %>
            <div class="tracker-card animate-fade-up delay-100">
                <div class="tracker-bar">
                    <!-- Progress line fill -->
                    <% 
                      let progressPercent = 0;
                      if (currentStatusIndex >= 0) {
                          progressPercent = (currentStatusIndex / (statusSteps.length - 1)) * 100;
                      }
                    %>
                    <div class="tracker-line-fill" style="width: <%= progressPercent %>%;"></div>

                    <% statusSteps.forEach((step,index)=>{ %>


                    <div 
                    class="
                    tracker-step 

                    <%= currentStatusIndex >= index 
                    ? 'completed' 
                    : '' %>


                    <%= currentStatusIndex === index
                    ? 'active'
                    : '' %>

                    "
                    >


                    <div class="step-icon-box">

                    <i class="fas <%= step.icon %>"></i>

                    </div>


                    <span class="step-label">

                    <%= step.name %>

                    </span>


                    <span class="step-sub">


                    <% if(currentStatusIndex >= index){ %>

                    Completed

                    <% } else { %>

                    Pending

                    <% } %>


                    </span>


                    </div>


                <% }); %>
                </div>
            </div>
            <% } else { %>


            <div class="tracker-card animate-fade-up delay-100">

                <h3>
                    Order Cancelled
                </h3>

                <p>
                    Your order has been cancelled.
                </p>

            </div>


            <% } %>

            <!-- MAIN TWO COLUMN GRID -->
            <div class="detail-grid animate-fade-up delay-200">
                
                <!-- LEFT COLUMN: Ordered Products List -->
                <div class="ordered-pieces-section">
                    <h2 class="section-title mb-4">Selected Pieces</h2>
                    
                    <div class="product-item-list">
                        <% order.items.forEach(item => { 
                            const isCancelled = item.status.toLowerCase() === 'cancelled';
                            const isDelivered = item.status.toLowerCase() === 'delivered';
                            const isProcessing = item.status.toLowerCase() === 'processing' || item.status.toLowerCase() === 'pending';                        %>
                            <div class="product-detail-card <%= isCancelled ? 'item-muted' : '' %>" data-item-id="<%= item._id %>" data-item-name="<%= item.productName %>">
                                <div class="prod-img">
                                    <img src="/uploads/products/<%= item.productImage %>" alt="<%= item.productName %>" onerror="this.src='/images/placeholder-shoe.png'">
                                </div>
                                <div class="prod-info">
                                    <div class="prod-info-header">
                                        <div>
                                            <h4 class="prod-name"><%= item.productName %></h4>
                                            <p class="prod-brand"><%= item.brand %></p>
                                        </div>
                                        <div class="prod-price-box">
                                            <span class="prod-price">₹<%= item.totalPrice.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                                            <span 
                                            class="prod-status-inline status-<%= item.status.toLowerCase().replaceAll(' ','-') %>"
                                            >

                                            <%= item.status %>

                                            </span>                                        </div>
                                    </div>
                                    <div class="prod-meta-footer">
                                        <div class="meta-qty-size">
                                            <span>QTY: <%= item.quantity %></span>
                                            <span class="meta-divider">•</span>
                                            <span>SIZE: <%= item.size %></span>
                                        </div>

                                        <!-- Conditional Action Buttons based on status -->
                                        <div class="prod-actions">
                                            <% if (isProcessing) { %>
                                                <button 
                                                class="btn btn-secondary btn-cancel-item"

                                                onclick="cancelItem(
                                                    '<%= order._id %>',
                                                    '<%= item._id %>'
                                                )"
                                            >

                                                <i class="fas fa-times"></i> 
                                                Cancel This Item

                                            </button>
                                            <% } else if (isDelivered) { %>
                                                <button 
                                                class="btn btn-secondary btn-return-item mr-2"

                                                onclick="returnItem(
                                                    '<%= order._id %>',
                                                    '<%= item._id %>'
                                                )"
                                                >

                                                <i class="fas fa-undo"></i>

                                                Return This Item

                                                </button> 
                                                <button class="btn btn-secondary btn-review-item" onclick="triggerWriteReview('<%= item.productId %>', '<%= item.productName %>')">
                                                    <i class="far fa-edit"></i> Write Review
                                                </button>
                                            <% } else if (isCancelled) { %>
                                                <span class="badge-cancelled-tag">Cancelled</span>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>

                <!-- RIGHT COLUMN: Order Meta & Financial Summary -->
                <div class="meta-billing-section">
                    
                    <!-- Delivery Address Card -->
                <% const address = order.address || {}; %>

<div class="luxury-info-card mb-4">

<h3 class="info-card-heading">
Delivery Address
</h3>

<div class="info-card-body">


<strong class="recipient-name">

<%= address.full_name %>

</strong>


<p class="recipient-address">

<%= address.address %>

</p>


<p class="recipient-city">

<%= address.city %>,
<%= address.state %> -
<%= address.pincode %>

</p>


<p class="recipient-phone">

<i class="fas fa-phone-alt"></i>

<%= address.phone_number %>

</p>


</div>

</div>

                    <!-- Payment Method Card -->
                    <div class="luxury-info-card mb-4">
                        <h3 class="info-card-heading">Payment Method</h3>
                        <div class="info-card-body payment-card-flex">
                            <i class="fas fa-credit-card payment-icon"></i>
                            <div>
                                <p class="payment-method-desc">

                                <%= 
                                order.paymentMethod === 'cod'
                                ? 'Cash On Delivery'
                                : order.paymentMethod === 'razorpay'
                                ? 'Online Payment'
                                : 'Wallet'
                                %>

                                </p>                            
                            </div>
                        </div>
                    </div>

                    <!-- Financial Summary Card -->
                    <div class="luxury-info-card mb-4">
                        <h3 class="info-card-heading">Financial Summary</h3>
                        <div class="info-card-body totals-list">
                            <div class="totals-row">
                                <span class="totals-label">Subtotal</span>
                                <span class="totals-value">₹<%= (order.subtotal || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                            </div>
                            <div class="totals-row">
                                <span class="totals-label">Shipping (Express)</span>
                                <span class="totals-value">₹<%= (order.shippingCharge || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                            </div>
                            <div class="totals-row">
                                <span class="totals-label">Estimated Tax</span>
                                <span class="totals-value">₹<%= (order.tax || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                            </div>
                            <% if (order.discount && order.discount > 0) { %>
                                <div class="totals-row discount-row">
                                    <span class="totals-label">Discount</span>
                                    <span class="totals-value">-₹<%= order.discount.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                                </div>
                            <% } %>
                            
                            <div class="totals-divider"></div>
                            
                            <div class="totals-row grand-total">
                                <span class="grand-total-label">Total</span>
                                <span class="grand-total-value">₹<%= (order.finalAmount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Support Card -->
                    <div class="support-concierge-card">
                        <div class="support-header">
                            <h3 class="support-heading">Need assistance?</h3>
                            <p class="support-subtitle">Our concierge is available for any questions regarding your shipment or product care.</p>
                        </div>
                        <a href="mailto:concierge@sneacks.com?subject=Inquiry regarding order <%= order.orderId %>" class="btn btn-accent support-btn-text">
                            Chat With An Expert
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </main>

    <!-- FOOTER -->
    <%- include('../partials/user/footer') %>

    <!-- Javascript Actions -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/user/order-details.js"></script>
</body>

</html>
