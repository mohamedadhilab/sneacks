<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Wishlist | SNEACKS</title>

    <!-- ICONS -->
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    >

    <!-- CSS -->
    <link rel="stylesheet" href="/styles/user/base.css">

    <link rel="stylesheet" href="/styles/user/layout.css?v=12">

    <link rel="stylesheet" href="/styles/user/components.css">

    <link rel="stylesheet" href="/styles/user/animations.css">

    <link rel="stylesheet" href="/styles/user/wishlist.css">

    <link rel="stylesheet" href="/styles/user/responsive.css">
</head>

<body>

    <!-- NAVBAR -->
    <%- include('../partials/user/navbar', {
        page: 'wishlist'
    }) %>

    <main class="page-wrapper">

        <div class="container section">

            <!-- HEADER -->
            <div class="text-center mb-4 animate-fade-up">

                <h1 class="m-0">
                    Wishlist
                </h1>

                <p class="text-muted mt-2">

                    Your curated selection
                    of SNEACKS essentials.

                </p>

            </div>

            <!-- ========================================= -->
            <!-- WISHLIST ITEMS -->
            <!-- ========================================= -->

            <% if (
                wishlist &&
                wishlist.items &&
                wishlist.items.length > 0
            ) { %>

                <div
                    class="wishlist-grid grid grid-4 animate-fade-in delay-100"
                >

                    <% wishlist.items.forEach(item => { %>

                        <% if(item.productId){ %>

                            <div
                                class="wishlist-item-wrapper relative"

                                data-id="<%= item.productId._id %>"
                            >

                                <!-- PRODUCT CARD -->

                                <%- include(
                                    '../partials/user/product-card',
                                    {
                                        product: item.productId,
                                        inWishlist: true
                                    }
                                ) %>

                                <!-- REMOVE BUTTON -->

                                <button

                                    class="wishlist-remove-btn"

                                    data-product-id="<%= item.productId._id %>"
                                >

                                    <i class="fas fa-times"></i>

                                </button>
                                <button

                                    class="btn btn-primary wishlist-cart-btn"

                                    onclick="window.location.href='/product/<%= item.productId._id %>'"
                                >

                                    Add To Cart

                                </button>

                            </div>

                        <% } %>

                    <% }) %>

                </div>

            <% } else { %>

                <!-- EMPTY STATE -->

                <%- include(
                    '../partials/user/empty-state',
                    {

                        iconClass: 'far fa-heart',

                        title:
                            'Your wishlist is empty',

                        message:
                            'Save your favorite products here and access them anytime.',

                        actionText:
                            'Continue Shopping',

                        actionLink:
                            '/shop'

                    }
                ) %>

            <% } %>

        </div>

    </main>

    <!-- FOOTER -->
    <%- include('../partials/user/footer') %>

    <!-- JS -->
    <script src="/js/user/wishlist.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</body>
</html>