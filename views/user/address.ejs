<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Addresses — Sneacks</title>
  <link rel="stylesheet" href="/styles/user/global.css" />
  <link rel="stylesheet" href="/styles/user/address.css" />
</head>
<body>

  <!-- ===== NAV ===== -->
  <nav class="site-nav">
    <a href="/home" class="nav-brand">Sneacks</a>
    <ul class="nav-links">
      <li><a href="/home">Home</a></li>
      <li><a href="#">Store</a></li>
      <li><a href="#">About Us</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
    <div class="nav-icons">
      <!-- Search -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7" /><line x1="16.5" y1="16.5" x2="22" y2="22" /></svg>
      <!-- Wishlist -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
      <!-- Account -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
      <!-- Cart -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
    </div>
  </nav>

  <!-- ===== ACCOUNT LAYOUT ===== -->
  <div class="account-layout">
    <aside class="account-sidebar">
      <h3 class="sidebar-title">MY ACCOUNT</h3>
      <ul class="sidebar-menu">
        <li><a href="/profile">PROFILE</a></li>
        <li><a href="/orders">ORDERS</a></li>
        <li><a href="/address" class="active">ADDRESS</a></li>
        <li><a href="/wallet">WALLET</a></li>
        <li class="logout-item">
<a href="#" class="logout-link" onclick="confirmLogout()">    
    <svg class="logout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
      <polyline points="16 17 21 12 16 7"></polyline>
      <line x1="21" y1="12" x2="9" y2="12"></line>
    </svg>

    <span>LOGOUT</span>

  </a>
</li>
      </ul>
    </aside>

    <main class="account-main">
      <div class="account-header address-header">
        <div>
          <h1 class="account-heading">Manage Addresses</h1>
          <p class="account-subheading">Maintain your delivery locations for a seamless checkout experience at the Atelier.</p>
        </div>
        <button class="btn-primary-sm btn-icon" onclick="openModal('addAddressModal')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          ADD NEW ADDRESS
        </button>
      </div>

     <div class="address-grid">

  <% if (addresses.length === 0) { %>
    <p>No addresses added yet.</p>
  <% } %>

  <% addresses.forEach(address => { %>
    <div class="address-card">

      <div class="address-card-header">
        <% if (address.is_default) { %>
          <span class="badge-default">DEFAULT</span>
        <% } else { %>
          <span></span>
        <% } %>

<% if(address.type === 'home'){ %>

  <!-- HOME ICON -->
  <svg class="address-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
    <polyline points="9 22 9 12 15 12 15 22"></polyline>
  </svg>

<% } else if(address.type === 'work'){ %>

  <!-- WORK ICON -->
  <svg class="address-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <rect x="3" y="7" width="18" height="13" rx="2"></rect>
    <path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
  </svg>

<% } else { %>

  <!-- OTHER ICON -->
  <svg class="address-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <circle cx="12" cy="12" r="9"></circle>
    <path d="M12 8h.01"></path>
    <path d="M11 12h1v4h1"></path>
  </svg>

<% } %>
      </div>

      <h3 class="address-name"><%= address.full_name %></h3>

      <div class="address-type-badge <%= address.type %>">
        <%= address.type.toUpperCase() %>
      </div>

      <p class="address-lines">
        <%= address.address %><br>
        <%= address.city %>, <%= address.state %> - <%= address.pincode %>
      </p>

      <div class="address-phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07"></path>
        </svg>
        <%= address.phone_number %>
      </div>

      <div class="address-actions">

        <!-- EDIT -->
        <button 
          class="btn-text-action"
          onclick="openEditModal(
            '<%= address._id %>',
            '<%= address.full_name %>',
            '<%= address.address %>',
            '<%= address.city %>',
            '<%= address.state %>',
            '<%= address.pincode %>',
            '<%= address.phone_number %>',
            '<%= address.type %>'
          )"
        >
          EDIT
        </button>

        <!-- DELETE -->
    <button
  type="button"
  class="btn-text-action text-danger delete-btn"
  onclick="confirmDelete('<%= address._id %>')"
>
  Delete
</button>

      </div>
    </div>
  <% }) %>

  <!-- ADD CARD -->
  <div class="address-card add-address-dash" onclick="openModal('addAddressModal')">
    <span>ADD NEW ADDRESS</span>
  </div>

</div>
    </main>
  </div>

  <!-- ===== ADD ADDRESS MODAL ===== -->
  <div class="modal-overlay" id="addAddressModal">
    <div class="modal-content modal-md">
      <div class="modal-header-centered">
        <span class="modal-tag">ACCOUNT &gt; ADDRESSES &gt; NEW ADDRESS</span>
        <h2>Add New Delivery Address</h2>
        <p>Set up your shipping destination to ensure your artisanal footwear reaches your doorstep with absolute precision.</p>
      </div>

      <div class="modal-body-card">
          <form action="/add-address" method="POST" class="edit-form grid-form">
          <div class="form-group full-width">
            <label class="form-label">FULL NAME</label>
            <input 
              type="text" 
              name="full_name" 
              class="form-input" 
              value="<%= user?.name || '' %>" 
              placeholder="Enter your name"
              required 
            />          
          </div>
          <div class="form-group full-width">
            <label class="form-label">STREET ADDRESS</label>
            <input type="text" name="address" class="form-input" placeholder="123 Cobbler's Lane" required />
          </div>
          
          <div class="form-group">
            <label class="form-label">CITY</label>
            <input type="text" name="city" class="form-input" placeholder="Florence" required />
          </div>
          <div class="form-group">
            <label class="form-label">STATE/PROVINCE</label>
            <input type="text" name="state" class="form-input" placeholder="Tuscany" required />
          </div>
          
          <div class="form-group">
            <label class="form-label">ZIP/POSTAL CODE</label>
            <input type="text" name="pincode" class="form-input" placeholder="50123" required />
          </div>
          <div class="form-group">
            <label class="form-label">PHONE NUMBER</label>
            <input 
              type="text" 
              name="phone_number" 
              class="form-input" 
              value="<%= user?.phone || '' %>" 
              placeholder="+91 234 567 8900"
              required 
            />          
          </div>
          <div class="form-group full-width">

  <label class="form-label">ADDRESS TYPE</label>

  <select name="type" class="form-input">

    <option value="home">Home</option>

    <option value="work">Work</option>

    <option value="other">Other</option>

  </select>

</div>

          <div class="form-group full-width checkbox-group">
            <label class="custom-checkbox">
              <input type="checkbox" name="is_default" value="true" />
              <span class="checkmark"></span>
              Set as my default shipping address
            </label>
          </div>
          
          <div class="modal-actions space-between">
            <button type="button" class="btn-text" onclick="closeModal('addAddressModal')">DISCARD CHANGES</button>
            <button type="submit" class="btn-primary-sm">SAVE ADDRESS</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ===== EDIT ADDRESS MODAL ===== -->
  <div class="modal-overlay" id="editAddressModal">
    <div class="modal-content modal-md">
      <div class="modal-header-centered">
        <span class="modal-tag">ACCOUNT SETTINGS</span>
        <h2>Edit Shipping Address</h2>
        <p>* Your shipping details are stored securely for a faster checkout experience.</p>
      </div>

      <div class="modal-body-card">
        <form id="editAddressForm" method="POST" class="edit-form grid-form">
          <div class="form-group full-width">
            <label class="form-label">FULL NAME</label>
            <input type="text" id="edit_full_name" name="full_name" class="form-input" required />
          </div>
          <div class="form-group full-width">
            <label class="form-label">STREET ADDRESS</label>
            <input type="text" id="edit_address" name="address" class="form-input" required />
          </div>
          
          <div class="form-group">
            <label class="form-label">CITY</label>
            <input type="text" id="edit_city" name="city" class="form-input" required />
          </div>
          <div class="form-group">
            <label class="form-label">STATE/PROVINCE</label>
            <input type="text" id="edit_state" name="state" class="form-input" required />
          </div>
          
          <div class="form-group">
            <label class="form-label">ZIP/POSTAL CODE</label>
            <input type="text" id="edit_pincode" name="pincode" class="form-input" required />
          </div>
          <div class="form-group">
            <label class="form-label">PHONE NUMBER</label>
            <input type="text" id="edit_phone_number" name="phone_number" class="form-input" required />
          </div>
          <div class="form-group full-width">

  <label class="form-label">ADDRESS TYPE</label>

  <select id="edit_type" name="type" class="form-input">

    <option value="home">Home</option>

    <option value="work">Work</option>

    <option value="other">Other</option>

  </select>

</div>

          <div class="form-group full-width checkbox-group">
            <label class="custom-checkbox">
              <input type="checkbox" id="edit_is_default" name="is_default" value="true" />
              <span class="checkmark"></span>
              Set as my default shipping address
            </label>
          </div>
          
          <div class="modal-actions">
            <button type="submit" class="btn-primary-sm">SAVE CHANGES</button>
            <button type="button" class="btn-text-secondary" onclick="closeModal('editAddressModal')">CANCEL</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ===== SITE FOOTER ===== -->
  <footer class="site-footer">
    <div class="footer-grid">
      <div>
        <div class="footer-brand-name">THE ATELIER</div>
        <p class="footer-brand-desc">
          A CURATED SPACE FOR THOSE WHO VALUE THE ART OF THE STEP. ARCHITECTURAL FOOTWEAR DESIGNED FOR THE MODERN ICONOCLAST.
        </p>
      </div>
      <div>
        <div class="footer-col-title">DISCOVER</div>
        <ul class="footer-col-links">
          <li><a href="#">COLLECTIONS</a></li>
          <li><a href="#">LIMITED EDITS</a></li>
          <li><a href="#">THE PROCESS</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">SERVICE</div>
        <ul class="footer-col-links">
          <li><a href="#">SHIPPING</a></li>
          <li><a href="#">RETURNS</a></li>
          <li><a href="#">CARE GUIDE</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom" style="display:flex; justify-content:space-between; align-items:center;">
      <span>© 2024 THE ATELIER. CRAFTED FOR THE CURATED FOOT.</span>
      <div style="display:flex; gap:20px;">
        <a href="#">PRIVACY POLICY</a>
        <a href="#">TERMS OF SERVICE</a>
      </div>
    </div>
  </footer>

  <script>
    function openModal(id) {
      document.getElementById(id).classList.add('active');
    }
    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
    }
    
    function openEditModal(id, fullName, address, city, state, pincode, phone,type) {
      // Set the action of the form to point to the update route with the correct id
      document.getElementById('editAddressForm').action = '/update-address/' + id;
      
      // Populate the fields
      document.getElementById('edit_full_name').value = fullName;
      document.getElementById('edit_address').value = address;
      document.getElementById('edit_city').value = city;
      document.getElementById('edit_state').value = state;
      document.getElementById('edit_pincode').value = pincode;
      document.getElementById('edit_phone_number').value = phone;
      document.getElementById('edit_type').value = type;
      
      openModal('editAddressModal');
    }
    function confirmDelete(id) {

  Swal.fire({

    title: 'Delete Address?',

    text: 'This address will be permanently removed.',

    icon: 'warning',

    showCancelButton: true,

    confirmButtonColor: '#556B2F',

    cancelButtonColor: '#A89F91',

    confirmButtonText: 'Yes, Delete',

    cancelButtonText: 'Cancel',

    reverseButtons: true,

    background: '#F6F1E9',

    color: '#2B2B2B'

  }).then((result) => {

    if (result.isConfirmed) {

      window.location.href = '/delete-address/' + id;

    }

  });
}


  function confirmLogout() {

  Swal.fire({

    title: 'Logout?',

    text: 'You will need to login again.',

    icon: 'question',

    showCancelButton: true,

    confirmButtonColor: '#556B2F',

    cancelButtonColor: '#A89F91',

    confirmButtonText: 'Yes, Logout',

    cancelButtonText: 'Stay Here',

    reverseButtons: true,

    background: '#F6F1E9',

    color: '#2B2B2B'

  }).then((result) => {

    if (result.isConfirmed) {

      window.location.href = '/logout';

    }

  });
}





  </script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<%- include("../partials/toast") %>
</body>
</html>
