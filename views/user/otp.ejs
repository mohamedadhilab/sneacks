<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sneacks — Verify Identity</title>

  <!-- ✅ correct path -->
  <link rel="stylesheet" href="/styles/user/global.css" />

  <style>
    body {
      min-height: 100vh;
      display: flex;
      background-color: var(--cream);
    }

    .left-panel {
      width: 50%;
      background: #e8e8e8;
      position: relative;
      overflow: hidden;
    }

    .left-panel img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .quote-text {
      position: absolute;
      bottom: 80px;
      left: 40px;
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.1rem;
      color: rgba(255, 255, 255, 0.75);
      max-width: 280px;
    }

    .right-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 60px;
    }

    .logo {
      margin-bottom: 80px;
      text-align: center;
    }

    .verify-content {
      width: 100%;
      max-width: 460px;
      text-align: center;
    }

    .verify-title {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      margin-bottom: 16px;
    }

    .verify-sub {
      font-size: 0.78rem;
      color: var(--text-mid);
      margin-bottom: 30px;
      line-height: 1.6;
    }

    .otp-input {
      width: 100%;
      padding: 16px;
      font-size: 1.3rem;
      text-align: center;
      letter-spacing: 10px;
      margin-bottom: 20px;
      border: 1px solid var(--border);
      background: var(--cream-light);
    }

    .error-text {
      color: red;
      font-size: 0.7rem;
      margin-bottom: 10px;
    }

    .resend-row {
  font-size: 0.65rem;
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

    .resend-row a {
      font-weight: 600;
      text-decoration: none;
      color: var(--text-dark);
    }

    .back-link {
      display: block;
      margin-top: 24px;
      font-size: 0.6rem;
      text-decoration: none;
      color: var(--text-light);
    }

    .back-link:hover {
      color: var(--text-dark);
    }

    .btn-text {
  background: none;
  border: none;
  font-size: 12px;
  color: var(--text-dark);
  cursor: pointer;
  font-weight: 600;
}

.btn-text:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}
  </style>
</head>

<body>

  <!-- LEFT -->
  <div class="left-panel">
    <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=800&q=90&grayscale" />
    <div class="quote-text">
      "Craftsmanship that steps beyond the ordinary."
    </div>
  </div>

  <!-- RIGHT -->
  <div class="right-panel">

    <div class="logo">
      <div class="logo-title">SNEACKS</div>
      <div class="logo-sub">The Curated Atelier</div>
    </div>

    <div class="verify-content">

      <h1 class="verify-title">Verify Your Identity</h1>
      <p class="verify-sub">
        Enter the 6-digit code sent to your email
      </p>

      <!-- ✅ error -->
     <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-text"><%= error %></div>
     <% } %>

      <!-- ✅ FORM -->
      <form action="/verify-otp" method="POST">

        <!-- important hidden fields -->
        <input type="hidden" name="email" value="<%= email %>" />
        <input type="hidden" name="purpose" value="<%= purpose %>" />

        <!-- OTP -->
        <input 
          type="text"
          name="otp"
          maxlength="6"
          class="otp-input"
          placeholder="------"
          required
        />

        <button type="submit" class="btn-primary">
          Verify
        </button>

      </form>

      <!-- resend -->
     <div class="resend-row">
        Didn’t receive?

        <button id="resendBtn" disabled class="btn-text">
          RESEND CODE
        </button>

        <div id="timerText">Resend in 30s</div>
      </div>

      <!-- back -->
      <a href="/login" class="back-link">
        ← Back to Login
      </a>

    </div>

  </div>
<div id="otpData" data-time="<%= otpTime || Date.now() %>"></div>

<script>
  const resendBtn = document.getElementById("resendBtn");
  const timerText = document.getElementById("timerText");

  const otpTimestamp = Number(
    document.getElementById("otpData").dataset.time
  ) || Date.now();

  const delay = 30;

  function startTimer() {
    const now = Date.now();
    let remaining = delay - Math.floor((now - otpTimestamp) / 1000);

    const interval = setInterval(() => {

      if (remaining <= 0) {
        clearInterval(interval);

        resendBtn.disabled = false;
        resendBtn.style.opacity = "1";
        timerText.innerText = "You can resend now";

      } else {
        resendBtn.disabled = true;
        resendBtn.style.opacity = "0.6";
        timerText.innerText = "Resend in " + remaining + "s";
        remaining--;
      }

    }, 1000);
  }

  startTimer();

  resendBtn.addEventListener("click", () => {
    window.location.href =
      "/resend-otp?email=<%= email %>&purpose=<%= purpose %>";
  });
</script>
</body>


</html>