<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sneacks — Set New Password</title>

  <link rel="stylesheet" href="/styles/user/global.css" />

  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background-color: var(--cream);
      font-family: 'Montserrat', sans-serif;
    }

    .main-row {
      display: flex;
      flex: 1;
    }

    .left-panel {
      width: 50%;
      height: 100vh;
      overflow: hidden;
      position: relative;
    }

    .left-panel img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .left-caption {
      position: absolute;
      bottom: 40px;
      left: 40px;
      color: rgba(255,255,255,0.6);
      font-style: italic;
    }

    .right-panel {
      width: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: var(--cream);
      padding: 40px;
    }

    .logo {
      margin-bottom: 30px;
      text-align: center;
    }

    .logo-title {
      font-size: 28px;
      letter-spacing: 4px;
      font-weight: 600;
    }

    .logo-sub {
      font-size: 10px;
      letter-spacing: 2px;
      color: gray;
    }

    .card {
      background: #f5f2ec;
      padding: 40px;
      border-radius: 6px;
      width: 100%;
      max-width: 380px;
      text-align: center;
    }

    .card h2 {
      font-family: 'Playfair Display', serif;
      margin-bottom: 10px;
    }

    .card p {
      font-size: 12px;
      color: #777;
      margin-bottom: 30px;
    }

    /* ===== PASSWORD FIELD ===== */
    .password-input-wrap {
      position: relative;
      width: 100%;
      margin-bottom: 16px;
    }

    .form-input {
      width: 100%;
      height: 48px;
      padding: 0 44px 0 14px; /* space for icon on right */
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 14px;
      box-sizing: border-box;
      outline: none;
      background: transparent;
    }

    .form-input:focus {
      border-color: #5b633f;
    }

    /* 👁 ICON (RIGHT SIDE) */
    .btn-eye {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      width: 22px;
      height: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      cursor: pointer;
    }

    .btn-eye svg {
      width: 18px;
      height: 18px;
      stroke: #888;
    }

    button.submit-btn {
      width: 100%;
      padding: 12px;
      background: #5b633f;
      color: white;
      border: none;
      border-radius: 4px;
      letter-spacing: 2px;
      cursor: pointer;
      margin-top: 10px;
    }

    button.submit-btn:hover {
      opacity: 0.9;
    }

    .back-link {
      display: block;
      margin-top: 15px;
      font-size: 12px;
      color: #555;
      text-decoration: none;
    }

    .footer {
      text-align: center;
      padding: 10px;
      font-size: 10px;
      color: #999;
      border-top: 1px solid #eee;
    }
  </style>
</head>

<body>

<div class="main-row">

  <!-- LEFT -->
  <div class="left-panel">
    <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=700&q=80">
    <div class="left-caption">Spring Collection 2024</div>
  </div>

  <!-- RIGHT -->
  <div class="right-panel">

    <div class="logo">
      <div class="logo-title">SNEACKS</div>
      <div class="logo-sub">THE CURATED ATELIER</div>
    </div>

    <div class="card">
      <h2>Set New Password</h2>
      <p>Please enter your new password below</p>

      <form action="/reset-password" method="POST">

        <input type="hidden" name="email" value="<%= email %>">

        <!-- PASSWORD -->
        <div class="password-input-wrap">
          <input type="password" name="password" class="form-input" placeholder="New Password" required>
          <button type="button" class="btn-eye" onclick="togglePassword(this)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>

        <!-- CONFIRM -->
        <div class="password-input-wrap">
          <input type="password" name="confirmPassword" class="form-input" placeholder="Confirm Password" required>
          <button type="button" class="btn-eye" onclick="togglePassword(this)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>

        <button type="submit" class="submit-btn">UPDATE PASSWORD</button>

      </form>

      <a href="/login" class="back-link">← Back to Login</a>
    </div>

  </div>

</div>

<div class="footer">
  © 2024 Sneacks Atelier. All Rights Reserved.
</div>

<script>
  function togglePassword(btn) {
    const input = btn.previousElementSibling;
    input.type = input.type === "password" ? "text" : "password";
  }
</script>

</body>
</html>