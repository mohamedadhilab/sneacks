<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password - SNEACKS Admin</title>
  <link rel="stylesheet" href="/styles/admin/admin-auth.css">
</head>
<body>
  
  <div class="bg-glow"></div>

  <header class="admin-header">
    <h1 class="admin-logo">SNEACKS</h1>
    <div class="admin-subtitle">KINETIC EDGE TERMINAL</div>
  </header>

  <main class="auth-card">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="admin-alert"><%= error %></div>
    <% } %>

    <div class="auth-icon-wrap">
      <div class="auth-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
          <path d="M3 3v5h5"></path>
          <rect x="10" y="10" width="4" height="6" rx="1"></rect>
          <path d="M12 10V8a2 2 0 0 0-4 0"></path>
        </svg>
      </div>
    </div>

    <h2 class="auth-card-title">Forgot Password</h2>
    <p class="auth-card-desc">Enter your admin email to receive OTP</p>
    
    <form action="/admin/forgot-password" method="POST">
      
      <div class="form-group">
        <label class="form-label">ADMIN EMAIL ADDRESS</label>
        <div class="input-wrap">
          <div class="input-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <input type="email" name="email" class="form-input" placeholder="name@sneacks.terminal" required>
        </div>
      </div>

      <button type="submit" class="btn-primary" style="margin-top: 1rem;">
        SEND OTP 
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>

    </form>

    <div class="back-link">
      <a href="/admin/login" class="btn-link">
        &lt; Back to Login
      </a>
    </div>

  </main>

  <div class="pager-dots">
    <div class="dot active"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>

<%- include("../partials/toast") %>
</body>
</html>
