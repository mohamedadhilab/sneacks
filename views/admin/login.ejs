<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Terminal - SNEACKS</title>
  <link rel="stylesheet" href="/styles/admin/admin-auth.css">
</head>
<body>
  
  <div class="bg-glow"></div>

  <header class="admin-header">
    <h1 class="admin-logo">SNEACKS</h1>
    <div class="admin-subtitle">ADMIN TERMINAL V2.4</div>
  </header>

  <main class="auth-card">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="admin-alert"><%= error %></div>
    <% } %>
    
    <form action="/admin/login" method="POST">
      
      <div class="form-group">
        <label class="form-label">EMAIL ADDRESS</label>
        <div class="input-wrap">
          <input type="email" name="email" class="form-input" placeholder="admin@sneacks.com" required style="padding-left: 14px;">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">
          PASSWORD
          <a href="/admin/forgot-password">Forgot?</a>
        </label>
        <div class="input-wrap">
          <input type="password" name="password" class="form-input" placeholder="••••••••" required style="padding-left: 14px;">
        </div>
      </div>

      <div class="checkbox-wrap">
        <input type="checkbox" id="keepLogged" name="keepLogged">
        <label for="keepLogged">Keep me logged in</label>
      </div>

      <button type="submit" class="btn-primary">Sign In</button>

    </form>

    <div class="portal-links">
      <div class="portal-links-row">
        <a href="#" class="portal-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            <path d="M2 12h20"></path>
          </svg>
          Internal Portal
        </a>
        <a href="#" class="portal-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
            <circle cx="12" cy="17" r="0.5"></circle>
          </svg>
          Support
        </a>
      </div>
    </div>
  </main>

  <footer class="auth-footer">
    <p>By logging in, you agree to SNEACKS Enterprise Privacy Policy and Terms of Service. This is a private system.</p>
  </footer>

  <div class="core-engine-text">
    <div class="main">CORE ENGINE</div>
    <div class="sub">AUTHORIZED</div>
  </div>

<%- include("../partials/toast") %>
</body>
</html>
