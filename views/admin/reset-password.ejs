<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - SNEACKS Admin</title>
  <link rel="stylesheet" href="/styles/admin/admin-auth.css">
</head>
<body>
  
  <div class="bg-glow"></div>

  <header class="admin-header">
    <h1 class="admin-logo">SNEACKS</h1>
    <div class="admin-subtitle">KINETIC INTELLIGENCE</div>
  </header>

  <main class="auth-card">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="admin-alert"><%= error %></div>
    <% } %>

    <h2 class="auth-card-title" style="text-align: left;">Reset Password</h2>
    <p class="auth-card-desc" style="text-align: left; margin-bottom: 2.5rem;">Secure your terminal access with a high-entropy passphrase.</p>
    
    <form action="/admin/reset-password" method="POST">
      <% if (typeof email !== 'undefined' && email) { %>
        <input type="hidden" name="email" value="<%= email %>">
      <% } %>

      <div class="form-group">
        <label class="form-label">NEW PASSWORD</label>
        <div class="input-wrap">
          <input type="password" name="password" class="form-input" placeholder="••••••••••••" required>
          <button type="button" class="input-action" onclick="togglePassword(this)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">CONFIRM PASSWORD</label>
        <div class="input-wrap">
          <input type="password" name="confirmPassword" class="form-input" placeholder="••••••••••••" required>
          <button type="button" class="input-action" onclick="togglePassword(this)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-primary" style="margin-top: 2rem;">
        Update Password 
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>

    </form>

    <div class="back-link">
      <a href="/admin/login" class="btn-link" style="text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.1em; margin-top: 2rem;">
        RETURN TO LOGIN
      </a>
    </div>

  </main>

  <div class="security-features">
    <div class="feature-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
      </svg>
      <span>ENCRYPTED</span>
    </div>
    <div class="feature-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
      </svg>
      <span>BIOMETRIC READY</span>
    </div>
    <div class="feature-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
      </svg>
      <span>INSTANT SYNC</span>
    </div>
  </div>

  <script>
    function togglePassword(btn) {
      const input = btn.previousElementSibling;
      input.type = input.type === 'password' ? 'text' : 'password';
    }
  </script>

</body>
</html>
