<!-- Toastify CSS -->
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

<!-- Custom Premium Validation & Toast Styles -->
<link rel="stylesheet" type="text/css" href="/styles/validation.css">

<!-- Toastify JS -->
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

<!-- Custom Premium Validation & Toast Logic -->
<script type="text/javascript" src="/js/toast.js"></script>
<script type="text/javascript" src="/js/validation.js"></script>

<script>
    /**
     * Backward-compatible reusable showToast wrapper
     * @param {string} text - Message content
     * @param {string} type - "success" | "error" | "warning" | "info"
     */
    function showToast(text, type) {
        if (window.Toast && typeof window.Toast[type] === 'function') {
            window.Toast[type](text);
        } else if (window.Toast && typeof window.Toast.info === 'function') {
            window.Toast.info(text);
        } else {
            console.warn('Toast utility not fully initialized. Text:', text);
        }
    }
</script>

<!-- Automatically trigger toast if message exists from res.locals.message -->
<% if (locals.message) { %>
<script>
    showToast(<%- JSON.stringify(locals.message.text) %>, <%- JSON.stringify(locals.message.type) %>);
</script>
<% } %>
