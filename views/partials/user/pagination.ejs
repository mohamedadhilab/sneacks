<% if (totalPages > 1) { %>
    <div class="pagination">
        <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %><%= queryString ? '&' + queryString : '' %>" class="page-item" aria-label="Previous">
                <i class="fas fa-chevron-left"></i>
            </a>
        <% } %>

        <% for(let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %><%= queryString ? '&' + queryString : '' %>" class="page-item <%= currentPage === i ? 'active' : '' %>">
                <%= i %>
            </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %><%= queryString ? '&' + queryString : '' %>" class="page-item" aria-label="Next">
                <i class="fas fa-chevron-right"></i>
            </a>
        <% } %>
    </div>
<% } %>
