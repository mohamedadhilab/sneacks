            <a href="/wishlist" class="nav-icon">
                <i class="far fa-heart"></i>
            </a>
            <a href="/profile" class="nav-icon">
                <i class="far fa-user"></i>
            </a>
            <a href="/cart" class="nav-icon">
                <i class="fas fa-shopping-bag"></i>
                <span class="cart-badge">0</span>
