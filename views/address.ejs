<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Addresses — Sneacks</title>
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="stylesheet" href="/styles/address.css" />
</head>
<body>

  <!-- ===== NAV ===== -->
  <nav class="site-nav">
    <a href="/home" class="nav-brand">Sneacks</a>
    <ul class="nav-links">
      <li><a href="/home">Home</a></li>
      <li><a href="#">Store</a></li>
      <li><a href="#">About Us</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
    <div class="nav-icons">
      <!-- Search -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7" /><line x1="16.5" y1="16.5" x2="22" y2="22" /></svg>
      <!-- Wishlist -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
      <!-- Account -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
      <!-- Cart -->
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
    </div>
  </nav>

  <!-- ===== ACCOUNT LAYOUT ===== -->
  <div class="account-layout">
    <aside class="account-sidebar">
      <h3 class="sidebar-title">MY ACCOUNT</h3>
      <ul class="sidebar-menu">
        <li><a href="/profile">PROFILE</a></li>
        <li><a href="/orders">ORDERS</a></li>
        <li><a href="/address" class="active">ADDRESS</a></li>
        <li><a href="/wallet">WALLET</a></li>
      </ul>
    </aside>

    <main class="account-main">
      <div class="account-header address-header">
        <div>
          <h1 class="account-heading">Manage Addresses</h1>
          <p class="account-subheading">Maintain your delivery locations for a seamless checkout experience at the Atelier.</p>
        </div>
        <button class="btn-primary-sm btn-icon" onclick="openModal('addAddressModal')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          ADD NEW ADDRESS
        </button>
      </div>

      <div class="address-grid">
        <!-- Address Card 1 (Default) -->
        <div class="address-card">
          <div class="address-card-header">
            <span class="badge-default">DEFAULT</span>
            <svg class="address-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          </div>
          <h3 class="address-name">Julianne Sterling</h3>
          <p class="address-lines">
            420 Artisanal Avenue, Studio 4B<br>
            Leather District, Boston, MA 02111<br>
            United States
          </p>
          <div class="address-phone">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            +1 (617) 555-0192
          </div>
          <div class="address-actions">
            <button class="btn-text-action" onclick="openModal('editAddressModal')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
              EDIT
            </button>
            <button class="btn-text-action text-danger">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
              REMOVE
            </button>
          </div>
        </div>

        <!-- Address Card 2 (Office) -->
        <div class="address-card">
          <div class="address-card-header">
            <span></span>
            <svg class="address-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
          </div>
          <h3 class="address-name">Julianne Sterling</h3>
          <p class="address-lines">
            The Design Loft - Atelier Office<br>
            88 Curated Way, Level 12<br>
            New York, NY 10013
          </p>
          <div class="address-phone">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            +1 (212) 555-0843
          </div>
          <div class="address-actions">
            <button class="btn-text-action" onclick="openModal('editAddressModal')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
              EDIT
            </button>
            <button class="btn-text-action text-danger">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
              REMOVE
            </button>
          </div>
        </div>

        <!-- Add Address Dash Card -->
        <div class="address-card add-address-dash" onclick="openModal('addAddressModal')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          <span>ADD A SEASONAL RESIDENCE</span>
        </div>
      </div>
    </main>
  </div>

  <!-- ===== ADD ADDRESS MODAL ===== -->
  <div class="modal-overlay" id="addAddressModal">
    <div class="modal-content modal-md">
      <div class="modal-header-centered">
        <span class="modal-tag">ACCOUNT &gt; ADDRESSES &gt; NEW ADDRESS</span>
        <h2>Add New Delivery Address</h2>
        <p>Set up your shipping destination to ensure your artisanal footwear reaches your doorstep with absolute precision.</p>
      </div>

      <div class="modal-body-card">
        <form class="edit-form grid-form">
          <div class="form-group full-width">
            <label class="form-label">FULL NAME</label>
            <input type="text" class="form-input" placeholder="E.g. Julian Atelier" />
          </div>
          <div class="form-group full-width">
            <label class="form-label">STREET ADDRESS</label>
            <input type="text" class="form-input" placeholder="123 Cobbler's Lane" />
          </div>
          <div class="form-group full-width">
            <label class="form-label">APARTMENT, SUITE, ETC. <span class="text-optional">(optional)</span></label>
            <input type="text" class="form-input" placeholder="Studio 4B" />
          </div>
          
          <div class="form-group">
            <label class="form-label">CITY</label>
            <input type="text" class="form-input" placeholder="Florence" />
          </div>
          <div class="form-group">
            <label class="form-label">STATE/PROVINCE</label>
            <input type="text" class="form-input" placeholder="Tuscany" />
          </div>
          
          <div class="form-group">
            <label class="form-label">ZIP/POSTAL CODE</label>
            <input type="text" class="form-input" placeholder="50123" />
          </div>
          <div class="form-group">
            <label class="form-label">COUNTRY</label>
            <select class="form-input select-input">
              <option>Italy</option>
              <option>United States</option>
              <option>United Kingdom</option>
            </select>
          </div>

          <div class="form-group full-width checkbox-group">
            <label class="custom-checkbox">
              <input type="checkbox" />
              <span class="checkmark"></span>
              Set as my default shipping address
            </label>
          </div>
          
          <div class="modal-actions space-between">
            <button type="button" class="btn-text" onclick="closeModal('addAddressModal')">DISCARD CHANGES</button>
            <button type="submit" class="btn-primary-sm">SAVE ADDRESS</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ===== EDIT ADDRESS MODAL ===== -->
  <div class="modal-overlay" id="editAddressModal">
    <div class="modal-content modal-md">
      <div class="modal-header-centered">
        <span class="modal-tag">ACCOUNT SETTINGS</span>
        <h2>Edit Shipping Address</h2>
        <p>* Your shipping details are stored securely for a faster checkout experience.</p>
      </div>

      <div class="modal-body-card">
        <form class="edit-form grid-form">
          <div class="form-group full-width">
            <label class="form-label">FULL NAME</label>
            <input type="text" class="form-input" value="Julianne Sterling" />
          </div>
          <div class="form-group full-width">
            <label class="form-label">STREET ADDRESS</label>
            <input type="text" class="form-input" value="420 Artisanal Avenue" />
          </div>
          <div class="form-group full-width">
            <label class="form-label">APARTMENT, SUITE, ETC. <span class="text-optional">(optional)</span></label>
            <input type="text" class="form-input" value="Studio 4B" />
          </div>
          
          <div class="form-group">
            <label class="form-label">CITY</label>
            <input type="text" class="form-input" value="Boston" />
          </div>
          <div class="form-group">
            <label class="form-label">STATE/PROVINCE</label>
            <input type="text" class="form-input" value="MA" />
          </div>
          
          <div class="form-group">
            <label class="form-label">ZIP/POSTAL CODE</label>
            <input type="text" class="form-input" value="02111" />
          </div>
          <div class="form-group">
            <label class="form-label">COUNTRY</label>
            <select class="form-input select-input">
              <option>United States</option>
              <option>Italy</option>
              <option>United Kingdom</option>
            </select>
          </div>

          <div class="form-group full-width checkbox-group">
            <label class="custom-checkbox">
              <input type="checkbox" checked />
              <span class="checkmark"></span>
              Set as my default shipping address
            </label>
          </div>
          
          <div class="modal-actions">
            <button type="submit" class="btn-primary-sm">SAVE CHANGES</button>
            <button type="button" class="btn-text-secondary" onclick="closeModal('editAddressModal')">CANCEL</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ===== SITE FOOTER ===== -->
  <footer class="site-footer">
    <div class="footer-grid">
      <div>
        <div class="footer-brand-name">THE ATELIER</div>
        <p class="footer-brand-desc">
          A CURATED SPACE FOR THOSE WHO VALUE THE ART OF THE STEP. ARCHITECTURAL FOOTWEAR DESIGNED FOR THE MODERN ICONOCLAST.
        </p>
      </div>
      <div>
        <div class="footer-col-title">DISCOVER</div>
        <ul class="footer-col-links">
          <li><a href="#">COLLECTIONS</a></li>
          <li><a href="#">LIMITED EDITS</a></li>
          <li><a href="#">THE PROCESS</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-col-title">SERVICE</div>
        <ul class="footer-col-links">
          <li><a href="#">SHIPPING</a></li>
          <li><a href="#">RETURNS</a></li>
          <li><a href="#">CARE GUIDE</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom" style="display:flex; justify-content:space-between; align-items:center;">
      <span>© 2024 THE ATELIER. CRAFTED FOR THE CURATED FOOT.</span>
      <div style="display:flex; gap:20px;">
        <a href="#">PRIVACY POLICY</a>
        <a href="#">TERMS OF SERVICE</a>
      </div>
    </div>
  </footer>

  <script>
    function openModal(id) {
      document.getElementById(id).classList.add('active');
    }
    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
    }
  </script>
</body>
</html>
