<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sneacks — Join the Atelier</title>

  <link rel="stylesheet" href="/styles/global.css" />

  <style>
    body {
      min-height: 100vh;
      display: flex;
      background-color: var(--cream);
    }

    .left-panel {
      width: 50%;
      background: #1c1c1c;
      overflow: hidden;
    }

    .left-panel img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.88;
    }

    .right-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 56px;
    }

    .auth-card {
      width: 100%;
      max-width: 420px;
    }
  </style>
</head>

<body>

  <div class="left-panel">
    <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=800&q=80" />
  </div>

  <div class="right-panel">

    <div class="logo">
      <div class="logo-title">SNEACKS</div>
      <div class="logo-sub">The Curated Atelier</div>
    </div>

    <div class="auth-card">
      <h1 class="card-title">Join the Atelier</h1>
      <p class="card-subtitle">Enter your details to create your digital membership</p>

      <!-- ✅ FORM START -->
      <form action="/signup" method="POST">

        <div class="form-group">
          <label class="form-label">Full Name</label>
          <input type="text" name="name" class="form-input" placeholder="Julian Vane" required />
        </div>

        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-input" placeholder="atelier@sneacks.com" required />
        </div>

        <div class="form-group">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-input" required />
        </div>

        <div class="form-group" style="margin-bottom: 28px;">
          <label class="form-label">Confirm Password</label>
          <input type="password" name="confirmPassword" class="form-input" required />
        </div>

        <button type="submit" class="btn-primary">Create Account</button>

      </form>
      <!-- ✅ FORM END -->

      <div class="or-divider">or continue with</div>

      <button class="btn-google">Continue with Google</button>

      <div class="auth-footer" style="margin-top: 16px;">
        Already have an account? <a href="/login">Log In</a>
      </div>

      <p class="legal-text">
        By joining, you agree to our Terms of Service and Privacy Policy
      </p>

    </div>
  </div>

</body>

</html>