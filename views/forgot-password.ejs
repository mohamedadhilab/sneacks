<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sneacks — Reset Your Password</title>

  <!-- Global CSS -->
  <link rel="stylesheet" href="/styles/global.css" />

  <style>
    body {
      min-height: 100vh;
      display: flex;
      background-color: var(--cream);
    }

    .left-panel {
      width: 50%;
      background: #1a0d00;
      position: relative;
      overflow: hidden;
    }

    .left-panel img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.85;
    }

    .est-badge {
      position: absolute;
      bottom: 48px;
      left: 40px;
      color: rgba(255, 255, 255, 0.65);
    }

    .est-line {
      width: 40px;
      height: 1px;
      background: rgba(255, 255, 255, 0.4);
      margin-bottom: 8px;
    }

    .est-badge span {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .right-panel {
      flex: 1;
      background: var(--cream);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 60px;
      position: relative;
    }

    .logo {
      margin-bottom: 60px;
      text-align: center;
    }

    .logo-title {
      font-size: 1.9rem;
      letter-spacing: 0.18em;
    }

    .reset-card {
      background: var(--cream-card);
      border-radius: 4px;
      padding: 48px;
      width: 100%;
      max-width: 420px;
    }

    .reset-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      text-align: center;
      margin-bottom: 12px;
    }

    .reset-sub {
      font-size: 0.78rem;
      text-align: center;
      margin-bottom: 32px;
      color: var(--text-mid);
    }

    .back-row {
      text-align: center;
      margin-top: 20px;
    }

    .error-text {
      color: red;
      font-size: 0.7rem;
      margin-bottom: 10px;
      text-align: center;
    }

    .page-footer {
      position: absolute;
      bottom: 24px;
      width: 100%;
      text-align: center;
      font-size: 0.55rem;
      letter-spacing: 0.14em;
      color: var(--text-placeholder);
    }
  </style>
</head>

<body>

  <!-- LEFT SIDE -->
  <div class="left-panel">
    <img src="https://images.unsplash.com/photo-1608231387042-66d1773070a5?w=800&q=80"
      alt="Sneaker background" />
    <div class="est-badge">
      <div class="est-line"></div>
      <span>Est. 2024</span>
    </div>
  </div>

  <!-- RIGHT SIDE -->
  <div class="right-panel">

    <!-- LOGO -->
    <div class="logo">
      <div class="logo-title">SNEACKS</div>
      <div class="logo-sub">The Curated Atelier</div>
    </div>

    <!-- CARD -->
    <div class="reset-card">

      <h1 class="reset-title">Reset Your Password</h1>
      <p class="reset-sub">
        Enter your email and we’ll send you a verification code.
      </p>

      <!-- 🔴 ERROR MESSAGE (optional backend use) -->
      <% if (error) { %>
        <div class="error-text"><%= error %></div>
      <% } %>

      <!-- FORM -->
      <form action="/forgot-password" method="POST">

        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input 
            type="email" 
            name="email"
            class="form-input"
            placeholder="name@domain.com"
            required
            autocomplete="email"
          />
        </div>

        <button type="submit" class="btn-primary">
          Send Reset Code
        </button>

      </form>

      <!-- BACK -->
      <div class="back-row">
        <a href="/login" class="back-link">← Back to Login</a>
      </div>

    </div>

    <!-- FOOTER -->
    <div class="page-footer">
      © 2024 Sneacks. Crafted for the Curated Eye.
    </div>

  </div>

</body>

</html>